  "nodes": {
    "q1c1": {
      "id": "q1c1",
      "text": "AI enhances access to information and collective cognition but not genuine knowledge or expertise",
      "type": "claim",
      "absorbed": [],
      "isFactual": false
    },
    "q1c2": {
      "id": "q1c2",
      "text": "AI obsolesces critical thinking, rote memorization, and the cognitive work of synthesis",
      "type": "claim",
      "absorbed": [],
      "isFactual": false
    },
    "q1c3": {
      "id": "q1c3",
      "text": "AI retrieves the encyclopedia, Socratic method, oracle, and uninhibited appetite for knowledge",
      "type": "claim",
      "absorbed": [],
      "isFactual": false
    },
    "q1c4": {
      "id": "q1c4",
      "text": "AI flips into cognitive surrender, lazy thinking, false confidence, and psychosis at the extreme",
      "type": "claim",
      "absorbed": [],
      "isFactual": false
    },
    "q1c5": {
      "id": "q1c5",
      "text": "The cognition being enhanced is narrow, missing somatic, institutional, and intuitive human intelligence",
      "type": "claim",
      "absorbed": [],
      "isFactual": false
    },
    "q2c1": {
      "id": "q2c1",
      "text": "AI enhances access to information but not actual knowledge or expertise.",
      "type": "claim",
      "absorbed": [],
      "isFactual": false
    },
    "q2c2": {
      "id": "q2c2",
      "text": "AI redefines expertise; many believe experts are no longer relevant.",
      "type": "claim",
      "absorbed": [],
      "isFactual": false
    },
    "q2c3": {
      "id": "q2c3",
      "text": "True expertise pushes boundaries of knowledge; AI only recombines what already exists.",
      "type": "claim",
      "absorbed": [],
      "isFactual": false
    },
    "q2c4": {
      "id": "q2c4",
      "text": "AI cannot capture somatic, intuitive, or institutional knowledge built through lived experience.",
      "type": "claim",
      "absorbed": [],
      "isFactual": false
    },
    "q2c5": {
      "id": "q2c5",
      "text": "AI lets anyone be an autodidact, giving ability to be expert without reason or earned mastery.",
      "type": "claim",
      "absorbed": [],
      "isFactual": false
    },
    "q3c1": {
      "id": "q3c1",
      "text": "A team is defined by shared mission, shared trust, shared identity, and shared history.",
      "type": "claim",
      "absorbed": [],
      "isFactual": false
    },
    "q3c2": {
      "id": "q3c2",
      "text": "When teams turn over every 21 days, they become cohorts or mere collections of people, not teams.",
      "type": "claim",
      "absorbed": [],
      "isFactual": false
    },
    "q3c3": {
      "id": "q3c3",
      "text": "A cohort assembles for a specific task and dissipates, while a team is dedicated and enduring.",
      "type": "claim",
      "absorbed": [],
      "isFactual": false
    },
    "q3c4": {
      "id": "q3c4",
      "text": "A team is a group working interconnectedly toward a common outcome, without needing to know each other.",
      "type": "claim",
      "absorbed": [],
      "isFactual": false
    },
    "q3c5": {
      "id": "q3c5",
      "text": "A real team works well together and finds value in collaboration, more like a band than a flash unit.",
      "type": "claim",
      "absorbed": [],
      "isFactual": false
    },
    "q4c1": {
      "id": "q4c1",
      "text": "The manager role is flipping from all-knowing expert to orchestrator and enabler of human and agent team members.",
      "type": "claim",
      "absorbed": [],
      "isFactual": false
    },
    "q4c2": {
      "id": "q4c2",
      "text": "The knowledge-hoarding technical manager is becoming obsolete; the orchestrator is the emerging figure.",
      "type": "claim",
      "absorbed": [],
      "isFactual": false
    },
    "q4c3": {
      "id": "q4c3",
      "text": "If an agent can manage you, it raises the question of why human management is needed at all.",
      "type": "claim",
      "absorbed": [],
      "isFactual": false
    },
    "q4c4": {
      "id": "q4c4",
      "text": "The manager's role shifts toward coaching humans and controlling the quality of output.",
      "type": "claim",
      "absorbed": [],
      "isFactual": false
    },
    "q4c5": {
      "id": "q4c5",
      "text": "AI empowers the decision-maker at the top while disempowering everyone not in the decision-making chair.",
      "type": "claim",
      "absorbed": [],
      "isFactual": false
    },
    "q5c1": {
      "id": "q5c1",
      "text": "AI enhances only a narrow definition of human cognition, missing somatic intelligence, institutional knowledge, and culture.",
      "type": "claim",
      "absorbed": [],
      "isFactual": false
    },
    "q5c2": {
      "id": "q5c2",
      "text": "Somatic, intuitive knowledge from years of hands-on practice cannot be captured in AI-generated procedures.",
      "type": "claim",
      "absorbed": [],
      "isFactual": false
    },
    "q5c3": {
      "id": "q5c3",
      "text": "Institutional knowledge is mostly lived experience and culture, not information, so AI cannot replace it.",
      "type": "claim",
      "absorbed": [],
      "isFactual": false
    },
    "q5c4": {
      "id": "q5c4",
      "text": "AI cannot replace human beings working together; humanity's biggest problems require people collaborating.",
      "type": "claim",
      "absorbed": [],
      "isFactual": false
    },
    "q5c5": {
      "id": "q5c5",
      "text": "True expertise pushes the boundaries of known knowledge; AI only patterns and recasts what already exists.",
      "type": "claim",
      "absorbed": [],
      "isFactual": false
    },
    "q6c1": {
      "id": "q6c1",
      "text": "AI obsolesces human utility value since machines outperform humans at nearly every utilitarian task",
      "type": "claim",
      "absorbed": [],
      "isFactual": false
    },
    "q6c2": {
      "id": "q6c2",
      "text": "AI forces fundamental questions of meaning, retrieving existentialism, nihilism, and philosophical inquiry",
      "type": "claim",
      "absorbed": [],
      "isFactual": false
    },
    "q6c3": {
      "id": "q6c3",
      "text": "Obsoleted utility threatens identity, leaving many feeling they're no longer valuable as humans",
      "type": "claim",
      "absorbed": [],
      "isFactual": false
    },
    "q6c4": {
      "id": "q6c4",
      "text": "In a post-capitalist frame, freed time could enhance leisure and self-worth beyond extraction of value",
      "type": "claim",
      "absorbed": [],
      "isFactual": false
    },
    "q6c5": {
      "id": "q6c5",
      "text": "AI enhances human purpose by amplifying agency, creativity, and craft as sources of meaning",
      "type": "claim",
      "absorbed": [],
      "isFactual": false
    },
    "q7c1": {
      "id": "q7c1",
      "text": "Work is automatically fun and non-hierarchical in small companies, turning shitty past ~100-150 people",
      "type": "claim",
      "absorbed": [],
      "isFactual": false
    },
    "q7c2": {
      "id": "q7c2",
      "text": "AI makes work more fun by removing minutiae, especially within a team",
      "type": "claim",
      "absorbed": [],
      "isFactual": false
    },
    "q7c3": {
      "id": "q7c3",
      "text": "Policy mandates dictating when and how to use AI make it predictable and drain the joy",
      "type": "claim",
      "absorbed": [],
      "isFactual": false
    },
    "q7c4": {
      "id": "q7c4",
      "text": "Return-to-office mandates, tracking, and policies suck the joy out of an inherently good experience",
      "type": "claim",
      "absorbed": [],
      "isFactual": false
    },
    "q7c5": {
      "id": "q7c5",
      "text": "Top talent comes to the office for fun, meaningful conversation, and friendship with smart peers",
      "type": "claim",
      "absorbed": [],
      "isFactual": false
    },
    "q8c1": {
      "id": "q8c1",
      "text": "Hiring should shift from credentials to demonstrated ability to make things",
      "type": "claim",
      "absorbed": [],
      "isFactual": false
    },
    "q8c2": {
      "id": "q8c2",
      "text": "Hire for thirst to learn and adaptability, not years of specific experience",
      "type": "claim",
      "absorbed": [],
      "isFactual": false
    },
    "q8c3": {
      "id": "q8c3",
      "text": "Education should be redesigned around later life stages, not stop after high school or college",
      "type": "claim",
      "absorbed": [],
      "isFactual": false
    },
    "q8c4": {
      "id": "q8c4",
      "text": "The old social contract—school, major, secure job—is collapsing before our eyes",
      "type": "claim",
      "absorbed": [],
      "isFactual": false
    },
    "q8c5": {
      "id": "q8c5",
      "text": "Performance standards and metrics must be reimagined away from output-based vanity KPIs",
      "type": "claim",
      "absorbed": [],
      "isFactual": false
    },
    "q9c1": {
      "id": "q9c1",
      "text": "AI doesn't take jobs; it amplifies the corporatism that invented employment.",
      "type": "claim",
      "absorbed": [],
      "isFactual": false
    },
    "q9c2": {
      "id": "q9c2",
      "text": "AI doesn't make students cheat; it amplifies education's existing metric-and-competition ground.",
      "type": "claim",
      "absorbed": [],
      "isFactual": false
    },
    "q9c3": {
      "id": "q9c3",
      "text": "Focusing on the technology itself obscures the larger institutional systems it challenges.",
      "type": "claim",
      "absorbed": [],
      "isFactual": false
    },
    "q9c4": {
      "id": "q9c4",
      "text": "People will eventually distinguish AI the tool from the institutions AI amplifies.",
      "type": "claim",
      "absorbed": [],
      "isFactual": false
    },
    "q9c5": {
      "id": "q9c5",
      "text": "AI's harms come from how it's mandated by policy, not from the tool itself.",
      "type": "claim",
      "absorbed": [],
      "isFactual": false
    },
    "q10c1": {
      "id": "q10c1",
      "text": "Team dynamics should be more lateral and collaborative, less hierarchical and dominant.",
      "type": "claim",
      "absorbed": [],
      "isFactual": false
    },
    "q10c2": {
      "id": "q10c2",
      "text": "AI obsolesces silos by forcing cross-disciplinary teams to actually work together.",
      "type": "claim",
      "absorbed": [],
      "isFactual": false
    },
    "q10c3": {
      "id": "q10c3",
      "text": "The hierarchical knowledge-hoarding manager is becoming obsolete; the orchestrator-enabler is emerging.",
      "type": "claim",
      "absorbed": [],
      "isFactual": false
    },
    "q10c4": {
      "id": "q10c4",
      "text": "AI empowers individual decision-makers, making team power asymmetric rather than collaborative.",
      "type": "claim",
      "absorbed": [],
      "isFactual": false
    },
    "q10c5": {
      "id": "q10c5",
      "text": "True teams need shared mission, trust, and identity, not just short-lived reshuffled cohorts.",
      "type": "claim",
      "absorbed": [],
      "isFactual": false
    }
  },
