  "nodes": {
    "n-cognitive-overload": {
      "id": "n-cognitive-overload",
      "type": "claim",
      "text": "AI/LLMs can create cognitive overload or even “psychosis” because they produce too much plausible, affirming output."
    },
    "n-sycophants": {
      "id": "n-sycophants",
      "type": "claim",
      "text": "LLMs are “sycophants” that tell users what they want to hear."
    },
    "n-agency-pushback": {
      "id": "n-agency-pushback",
      "type": "claim",
      "text": "We actually have even more agency than we sometimes think, especially since we can push back on AI anytime"
    },
    "n-humans-tell-too": {
      "id": "n-humans-tell-too",
      "type": "claim",
      "text": "Humans also tell people what they want to hear, so this is not unique to AI."
    },

    "n-friction-deliberation": { "id": "n-friction-deliberation", "type": "claim", "text": "Friction forces deliberation that fast tools bypass." },
    "n-friction-access": { "id": "n-friction-access", "type": "claim", "text": "Removing friction democratizes access to expertise." },
    "n-friction-q": { "id": "n-friction-q", "type": "question", "text": "Which decisions actually benefit from being slow?" },
    "n-friction-q-irreversible": { "id": "n-friction-q-irreversible", "type": "claim", "text": "Decisions that are irreversible, like firing someone, deserve a slow path." },
    "n-friction-q-reversible": { "id": "n-friction-q-reversible", "type": "claim", "text": "Reversible, low-stakes decisions benefit from speed, not deliberation." },

    "n-jobs-bullshit": { "id": "n-jobs-bullshit", "type": "claim", "text": "Many roles were already bullshit jobs by design." },
    "n-jobs-transition": { "id": "n-jobs-transition", "type": "claim", "text": "Job loss is a transition cost, not an indictment of the work." },
    "n-jobs-q": { "id": "n-jobs-q", "type": "question", "text": "What makes a job meaningful in the first place?" },
    "n-jobs-q-craft": { "id": "n-jobs-q-craft", "type": "claim", "text": "Meaning comes from craft — work that compounds skill over time." },
    "n-jobs-q-service": { "id": "n-jobs-q-service", "type": "claim", "text": "Meaning comes from service — visible impact on other people." },

    "n-agency-atrophy": { "id": "n-agency-atrophy", "type": "claim", "text": "Outsourcing cognition atrophies the underlying skill." },
    "n-agency-judgment": { "id": "n-agency-judgment", "type": "claim", "text": "AI lets humans focus on higher-order judgment." },
    "n-agency-q": { "id": "n-agency-q", "type": "question", "text": "Surrender to what end?" },
    "n-agency-q-leisure": { "id": "n-agency-q-leisure", "type": "claim", "text": "Surrender frees us for leisure, family, and the things machines can't do." },
    "n-agency-q-drift": { "id": "n-agency-q-drift", "type": "claim", "text": "Surrender without a chosen end is drift — we end up serving whoever set the defaults." }
  },
